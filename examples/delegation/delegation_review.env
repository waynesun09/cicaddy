# Example: Delegated code review with sub-agent delegation
#
# This configuration enables AI-powered sub-agent delegation for code reviews.
# The triage AI analyzes the diff and activates relevant specialist reviewers
# (security, architecture, performance, etc.) in parallel.
#
# Usage:
#   cicaddy run --env-file examples/delegation/delegation_review.env

# --- AI Provider ---
AI_PROVIDER=gemini
AI_MODEL=gemini-3-flash
GEMINI_API_KEY=your-api-key-here

# --- Agent Type ---
# For standalone code review (not triggered by MR/PR), use task agent with
# code_review task type. Platform plugins (cicaddy-gitlab, cicaddy-action)
# auto-detect merge_request/pull_request agent types in CI.
AGENT_TYPE=task
TASK_TYPE=code_review

# --- Delegation ---
DELEGATION_MODE=auto              # Enable AI-powered sub-agent delegation
MAX_SUB_AGENTS=3                  # Up to 3 sub-agents in parallel
SUB_AGENT_MAX_ITERS=5             # Each sub-agent gets 5 iterations max

# Custom sub-agent YAML directory (default: .agents/delegation)
# DELEGATION_AGENTS_DIR=.agents/delegation

# Optional: custom triage instructions
# TRIAGE_PROMPT=Focus on security and performance for this review

# Optional: inline custom agent definitions (JSON)
# DELEGATION_AGENTS=[{"name": "my-reviewer", "agent_type": "review", "persona": "...", "description": "...", "categories": ["security"]}]

# --- Execution ---
MAX_INFER_ITERS=30
LOG_LEVEL=INFO

# --- Local Tools (for reading source files during review) ---
ENABLE_LOCAL_TOOLS=true
LOCAL_TOOLS_WORKING_DIR=.
